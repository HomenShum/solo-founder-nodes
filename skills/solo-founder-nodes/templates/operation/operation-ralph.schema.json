{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solo-founder-nodes.local/operation-ralph.schema.json",
  "title": "Solo Founder Operation RALPH Receipt",
  "type": "object",
  "required": ["schemaVersion", "receiptKind", "goal", "domain", "doctrine", "operations"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "receiptKind": { "const": "operation-ralph" },
    "goal": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "doctrine": {
      "type": "object",
      "required": ["objectProofIsNotWorkflowProof", "beforeAfterProofRequired", "failedOperationsBlockParentClaim"],
      "properties": {
        "objectProofIsNotWorkflowProof": { "const": true },
        "beforeAfterProofRequired": { "const": true },
        "failedOperationsBlockParentClaim": { "const": true }
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["operationId", "label", "domain", "required", "expected", "proof", "ralph", "verdict"],
        "properties": {
          "operationId": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "domain": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "expected": { "type": "object" },
          "proof": { "type": "object" },
          "verdict": { "enum": ["pass", "partial", "fail"] }
        }
      }
    }
  }
}
